# Global
NODE_ENV=development
TZ=UTC
APP_TIMEZONE=Africa/Accra

# Backend
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tnma_revenue?schema=public
JWT_SECRET=replace_me
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=replace_me_refresh
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# SMS
SMS_PROVIDER=dryrun
MNOTIFY_API_KEY=replace_me
MNOTIFY_SENDER_ID=TNMA
HUBTEL_CLIENT_ID=replace_me
HUBTEL_CLIENT_SECRET=replace_me
ARKESEL_API_KEY=replace_me

# Email
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=replace_me
SMTP_FROM=billing@tnma.gov.gh

# Payments
MOMO_API_KEY=replace_me
MOMO_API_SECRET=replace_me
TELECEL_CASH_API_KEY=replace_me
AIRTELTIGO_MONEY_API_KEY=replace_me

# Desktop
VITE_API_BASE_URL=http://localhost:3000

# Mobile
MOBILE_API_BASE_URL=http://10.0.2.2:3000
